{
    "flow_api_url": {
        "description": "【Flow模式】API地址",
        "type": "string",
        "hint": "Flow模式(OpenAI格式)专用，支持翻译和多图。",
        "default": "http://localhost:8000/v1/chat/completions"
    },
    "flow_api_key": {
        "description": "【Flow模式】API Key",
        "type": "string",
        "hint": "Flow模式使用的API密钥。",
        "default": ""
    },
    "flow_default_model": {
        "description": "【Flow模式】默认模型",
        "type": "string",
        "hint": "Flow模式默认使用的模型ID（横版），会根据图片比例自动切换。",
        "default": "gemini-3.0-pro-image-landscape"
    },
    "flow_model_list": {
        "description": "【Flow模式】可用模型列表",
        "type": "list",
        "hint": "Flow模式可切换的模型列表，会根据图片比例自动选择横版/竖版。",
        "items": {
            "type": "string"
        },
        "default": [
            "gemini-3.0-pro-image-landscape",
            "gemini-3.0-pro-image-portrait"
        ]
    },
    "flow_enable_translate": {
        "description": "【Flow模式】启用翻译",
        "type": "bool",
        "hint": "开启后自动将中文提示词翻译为英文。",
        "default": false
    },
    "flow_baidu_appid": {
        "description": "【Flow模式】百度翻译AppID",
        "type": "string",
        "default": "",
        "condition": {
            "flow_enable_translate": true
        }
    },
    "flow_baidu_key": {
        "description": "【Flow模式】百度翻译密钥",
        "type": "string",
        "default": "",
        "condition": {
            "flow_enable_translate": true
        }
    },
    "generic_api_url": {
        "description": "【Generic模式】API地址",
        "type": "string",
        "hint": "Generic模式(OpenAI通用格式)专用。",
        "default": "https://api.example.com/v1/chat/completions"
    },
    "generic_api_keys": {
        "description": "【Generic模式】API Key池",
        "type": "list",
        "hint": "Generic模式Key池，支持轮询。",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "generic_default_model": {
        "description": "【Generic模式】默认模型",
        "type": "string",
        "default": "nano-banana"
    },
    "generic_api_format": {
        "description": "【Generic模式】API格式",
        "type": "string",
        "hint": "选择API调用格式。使用Gemini模型时请选'gemini'格式，否则选'openai'格式。",
        "default": "openai",
        "options": [
            "openai",
            "gemini"
        ]
    },
    "generic_resolution": {
        "description": "【Generic模式】输出分辨率",
        "type": "string",
        "hint": "支持Gemini模型的分辨率设置。",
        "default": "1K",
        "options": [
            "1K",
            "2K",
            "4K"
        ]
    },
    "generic_aspect_ratio": {
        "description": "【Generic模式】宽高比",
        "type": "string",
        "hint": "文生图时的宽高比。选择'自动'让模型自动决定。图生图会自动使用输入图片的比例。",
        "default": "自动",
        "options": [
            "自动",
            "1:1",
            "2:3",
            "3:2",
            "3:4",
            "4:3",
            "9:16",
            "16:9"
        ]
    },
    "gemini_api_url": {
        "description": "【Gemini模式】API地址",
        "type": "string",
        "hint": "Gemini官方API地址。",
        "default": "https://generativelanguage.googleapis.com"
    },
    "gemini_api_keys": {
        "description": "【Gemini模式】API Key池",
        "type": "list",
        "hint": "Gemini模式Key池，支持轮询。",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "gemini_default_model": {
        "description": "【Gemini模式】默认模型",
        "type": "string",
        "default": "gemini-3-pro-image-preview"
    },
    "gemini_resolution": {
        "description": "【Gemini模式】输出分辨率",
        "type": "string",
        "hint": "Gemini官方API支持的输出分辨率。4K可获得最高质量。",
        "default": "4K",
        "options": [
            "1K",
            "2K",
            "4K"
        ]
    },
    "gemini_use_image_config": {
        "description": "【Gemini模式】使用imageConfig参数",
        "type": "bool",
        "hint": "启用后使用imageConfig设置分辨率（推荐，适配CPA渠道）。关闭则使用aspectRatio方式（旧版官方）。",
        "default": true
    },
    "p_api_base_url": {
        "description": "【P模式】ChatGPT2API地址",
        "type": "string",
        "hint": "ChatGPT2API OpenAI兼容图片API根地址，通常以 /v1 结尾；Docker内访问宿主机时可改为宿主机网关地址。",
        "default": "http://localhost:3010/v1"
    },
    "p_api_key": {
        "description": "【P模式】ChatGPT2API密钥",
        "type": "string",
        "hint": "chatgpt2api 的 auth-key，请求时会作为 Bearer Token 使用。请勿公开真实密钥。",
        "default": ""
    },
    "p_default_model": {
        "description": "【P模式】默认模型",
        "type": "string",
        "hint": "ChatGPT2API 图片模型，默认使用 gpt-image-2，也可改为 gpt-image-1。",
        "default": "gpt-image-2",
        "options": [
            "gpt-image-2",
            "gpt-image-1"
        ]
    },
    "p_image_count": {
        "description": "【P模式】单次图片数量",
        "type": "int",
        "hint": "ChatGPT2API 单次返回图片数量，后端支持 1-4。",
        "default": 1
    },
    "p_response_format": {
        "description": "【P模式】响应格式",
        "type": "string",
        "hint": "当前插件按 b64_json 解码图片。",
        "default": "b64_json",
        "options": [
            "b64_json"
        ]
    },
    "default_mode": {
        "description": "【通用】白名单默认API模式",
        "type": "string",
        "hint": "白名单用户使用无前缀命令时的默认模式。",
        "default": "generic",
        "options": [
            "flow",
            "generic",
            "gemini",
            "p"
        ]
    },
    "normal_user_default_mode": {
        "description": "【通用】普通用户默认模式",
        "type": "string",
        "hint": "普通用户使用无前缀命令时的默认模式。",
        "default": "flow",
        "options": [
            "flow",
            "generic",
            "gemini",
            "p"
        ]
    },
    "default_mode_schedule": {
        "description": "【通用】定时切换默认模式",
        "type": "list",
        "hint": "格式: HH:MM=模式 (支持 f/o/g/p 或 flow/generic/gemini/chatgpt2api)。每天该时间自动切换，可多条。",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "enable_flow_mode": {
        "description": "【模式开关】启用Flow模式",
        "type": "bool",
        "hint": "关闭后，所有f开头的指令和Flow模式将不可用。",
        "default": true
    },
    "enable_generic_mode": {
        "description": "【模式开关】启用Generic模式",
        "type": "bool",
        "hint": "关闭后，所有o开头的指令和Generic模式将不可用。",
        "default": true
    },
    "enable_gemini_mode": {
        "description": "【模式开关】启用Gemini模式",
        "type": "bool",
        "hint": "关闭后，所有g开头的指令和Gemini模式将不可用。",
        "default": true
    },
    "enable_p_mode": {
        "description": "【模式开关】启用P模式",
        "type": "bool",
        "hint": "关闭后，所有p开头的指令和ChatGPT2API模式将不可用。",
        "default": true
    },
    "daily_limit": {
        "description": "【次数】每日限制次数",
        "type": "int",
        "hint": "每个用户每日可使用的次数。白名单用户无限制。",
        "default": 5
    },
    "custom_limits": {
        "description": "【次数】自定义用户额度",
        "type": "text",
        "editor_mode": true,
        "editor_language": "json",
        "hint": "JSON格式: {\"用户ID\": 次数}",
        "default": "{}"
    },
    "user_whitelist": {
        "description": "【权限】用户白名单",
        "type": "list",
        "hint": "白名单用户无任何限制，可使用所有模式。",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "group_whitelist": {
        "description": "【权限】群聊白名单",
        "type": "list",
        "hint": "白名单群聊可使用所有模式，但受次数限制。LLM绘图工具也使用此白名单。",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "enable_llm_tool": {
        "description": "【LLM】注册为LLM工具",
        "type": "bool",
        "hint": "开启后可通过对话让AI调用绘图功能。",
        "default": false
    },
    "llm_default_mode": {
        "description": "【LLM】默认模式",
        "type": "string",
        "hint": "LLM绘图工具使用的默认模式。所有用户统一使用此配置。",
        "default": "generic",
        "options": [
            "flow",
            "generic",
            "gemini",
            "p"
        ]
    },
    "llm_tool_use_group_limit": {
        "description": "【LLM】使用群级次数统计",
        "type": "bool",
        "hint": "开启后，LLM绘图工具按群统计次数。关闭则按个人统计。",
        "default": true
    },
    "llm_group_daily_limit": {
        "description": "【LLM】群每日限额",
        "type": "int",
        "hint": "非白名单群每日LLM绘图次数上限（仅群统计模式有效）。",
        "default": 10
    },
    "llm_group_whitelist": {
        "description": "【LLM】群白名单",
        "type": "list",
        "hint": "已废弃-请使用群聊白名单。为向后兼容保留此配置。",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "llm_last_image_ttl": {
        "description": "【LLM】上一次图片缓存TTL(秒)",
        "type": "int",
        "hint": "LLM工具使用上一次图片的缓存时间。0表示不过期。",
        "default": 3600
    },
    "llm_last_image_max_entries": {
        "description": "【LLM】上一次图片缓存最大条数",
        "type": "int",
        "hint": "全局缓存条数上限（跨会话）。强制最大为5，避免内存占用过大。",
        "default": 5
    },
    "enable_auto_recall": {
        "description": "【撤回】启用自动撤回",
        "type": "bool",
        "hint": "开启后，本插件发送的消息会自动撤回（是否成功取决于平台）。",
        "default": false
    },
    "auto_recall_delay": {
        "description": "【撤回】撤回延迟(秒)",
        "type": "int",
        "hint": "自动撤回的延迟时间，不填默认15秒。",
        "default": 15
    },
    "debug_mode": {
        "description": "【调试】启用调试模式",
        "type": "bool",
        "hint": "开启后会在日志中输出详细的API请求和响应信息，便于排查问题。",
        "default": false
    },
    "flow_use_proxy": {
        "description": "【Flow模式】启用代理",
        "type": "bool",
        "hint": "Flow模式是否使用代理。",
        "default": false
    },
    "generic_use_proxy": {
        "description": "【Generic模式】启用代理",
        "type": "bool",
        "hint": "Generic模式是否使用代理。",
        "default": false
    },
    "gemini_use_proxy": {
        "description": "【Gemini模式】启用代理",
        "type": "bool",
        "hint": "Gemini模式是否使用代理。",
        "default": true
    },
    "p_use_proxy": {
        "description": "【P模式】启用代理",
        "type": "bool",
        "hint": "P模式是否使用代理。对接本机ChatGPT2API时通常关闭。",
        "default": false
    },
    "proxy_url": {
        "description": "【网络】代理地址",
        "type": "string",
        "hint": "格式: http://172.17.0.1:7890",
        "default": "http://172.17.0.1:7890"
    },
    "timeout": {
        "description": "【网络】请求超时(秒)",
        "type": "int",
        "default": 120
    },
    "enable_retry": {
        "description": "【网络】启用生成重试",
        "type": "bool",
        "hint": "关闭后只尝试一次，忽略最大重试次数设置。",
        "default": true
    },
    "max_retries": {
        "description": "【网络】最大重试次数",
        "type": "int",
        "hint": "生成失败时的重试次数（启用重试时生效）。",
        "default": 3
    },
    "retry_delay": {
        "description": "【网络】重试间隔(秒)",
        "type": "int",
        "hint": "重试基础间隔秒数。使用指数退避：第1次等待N秒，第2次等待2N秒...",
        "default": 2
    },
    "prompt_list": {
        "description": "【预设】提示词预设列表",
        "type": "list",
        "hint": "格式: 触发词:提示词内容",
        "items": {
            "type": "string"
        },
        "default": []
    },
    "help_text": {
        "description": "【帮助】帮助文本",
        "type": "text",
        "editor_mode": true,
        "default": "🎨 RongheDraw 绘图插件\n\n━━ 快速开始 ━━\n#f文 <描述>      Flow文字生成图片\n#p文 <描述>      ChatGPT2API文字生成图片\n#f图 [图片]      Flow图片风格转换\n#p图 [图片]      ChatGPT2API图片编辑\n#f随机 [图片]    Flow随机预设效果\n#p随机 [图片]    ChatGPT2API随机预设效果\n#<预设名> [图片] 预设效果（支持 #/ 前缀与 f/o/g/p 指定模式）\n\n━━ API模式 ━━\nf = Flow (自动横竖版，支持翻译)\no = Generic (仅白名单)\ng = Gemini (仅白名单, 4K输出)\np = ChatGPT2API (OpenAI图片兼容, 默认gpt-image-2)\n\n示例: #o文 <描述>  #g图 [图片]  #p文 <描述>\n示例: #鬼图  #fQ版化  /g痛车化  #p手办化\n\n━━ 权限 ━━\n普通用户: 仅 #f 命令，若普通默认模式设为p则可用 #p\n白名单: 所有模式\n\n━━ 管理 ━━\n#查询次数 | #预设列表\n#生图菜单 | #生图帮助\n#切换到 f/o/g/p\n#f翻译开关\n\n━━ 输入限制 ━━\n提示词 < 900 字符\n图片 <= 10 张\n\n━━ LLM提示 ━━\n继续改图: 说“继续修改/基于上次”\n分辨率: resolution=1K/2K/4K (仅Generic/Gemini)\n\n有问题加群：1075544978"
    }
}
